---
interface Props {
	title: string;
	description: string;
	heroImage: string;
	category: string;
}

const {
	title,
	description,
	heroImage,
	category,
} = Astro.props;
---

<section class="relative">
	<!-- Hero Image -->
	<div class="relative h-96 md:h-[500px] lg:h-[700px] overflow-hidden rounded-xl shadow-2xl mb-12">
		<img
			src={heroImage}
			alt={title}
			class="w-full h-full object-cover"
		/>
		<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
		<div class="absolute inset-0 flex flex-col justify-end items-start p-6 md:p-12">
			<h2 class="text-4xl md:text-5xl font-bold text-white mb-2">{title}</h2>
			<p class="text-lg md:text-xl text-gray-200 max-w-2xl">{description}</p>
		</div>
	</div>
</section>
