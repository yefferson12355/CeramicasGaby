---
const navItems = [
	{ name: 'BAÑO', href: '/banos' },
	{ name: 'COCINA', href: '/cocina' },
	{ name: 'SALA', href: '/sala' },
	{ name: 'TERRAZA', href: '/terraza' },
	{ name: 'NUEVOS', href: '/nuevos' },
];

const accesorios = [
	{ name: 'PORCELANATO', href: '/porcelanato' },
	{ name: 'LISTELOS', href: '/listelos' },
	{ name: 'ADHESIVOS', href: '/adhesivos' },
	{ name: 'HERRAMIENTAS', href: '/herramientas' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50	">
	<div class="container mx-auto px-4 py-5 md:py-6">
		<div class="flex items-center justify-between gap-8">
			<!-- Logo -->
			<a href="/" class="flex-shrink-0 group">
				<h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-blue-600 to-blue-500 bg-clip-text text-transparent group-hover:from-blue-700 group-hover:to-blue-600 transition-all duration-200">
					CERÁMICAS GABI
				</h1>
			</a>

			<!-- Desktop Navigation -->
			<nav class="hidden lg:flex items-center space-x-1 flex-1 ml-8">
				{navItems.map((item) => {
					const isActive = currentPath === item.href;
					return (
						<a
							href={item.href}
							class={`font-medium text-sm px-4 py-2 rounded-md transition-all duration-200 relative group ${
								isActive
									? 'text-blue-600 bg-blue-50'
									: 'text-gray-600 hover:text-blue-600'
							}`}
						>
							{item.name}
							{!isActive && (
								<span class="absolute bottom-0 left-4 right-4 h-0.5 bg-blue-600 scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
							)}
							{isActive && (
								<span class="absolute bottom-0 left-4 right-4 h-0.5 bg-blue-600 scale-x-100"></span>
							)}
						</a>
					);
				})}

				<!-- ACCESORIOS Dropdown -->
				<div class="relative group">
					<button class="font-medium text-sm px-4 py-2 rounded-md transition-all duration-200 text-gray-600 hover:text-blue-600 flex items-center gap-1 group-hover:text-blue-600">
						ACCESORIOS
						<svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
						</svg>
					</button>
					
					<!-- Dropdown Menu -->
					<div class="absolute left-0 mt-0 w-48 bg-white border border-gray-200 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2 z-50">
						{accesorios.map((item) => {
							const isActive = currentPath === item.href;
							return (
								<a
									href={item.href}
									class={`block px-4 py-2 text-sm font-medium transition-colors duration-200 ${
										isActive
											? 'text-blue-600 bg-blue-50'
											: 'text-gray-700 hover:text-blue-600 hover:bg-gray-50'
									}`}
								>
									{item.name}
								</a>
							);
						})}
					</div>
				</div>
			</nav>

			<!-- Search Desktop Only -->
			<div class="relative hidden lg:block flex-shrink-0">
				<input
					type="text"
					placeholder="Buscar..."
					class="bg-gray-50 border border-gray-200 rounded-lg py-2.5 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white focus:border-transparent w-56 transition-all duration-200 text-sm font-medium"
				/>
				<svg
					class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
					></path>
				</svg>
			</div>

			<!-- Mobile Menu Button -->
			<button id="mobile-menu-btn" class="lg:hidden p-2.5 hover:bg-blue-50 rounded-lg transition-colors duration-200 flex-shrink-0" aria-label="Menú">
				<svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
				</svg>
			</button>
		</div>

		<!-- Mobile Navigation -->
		<nav id="mobile-menu" class="lg:hidden hidden mt-4 pt-4 border-t border-gray-100">
			<div class="flex flex-col space-y-1">
				{navItems.map((item) => {
					const isActive = currentPath === item.href;
					return (
						<a
							href={item.href}
							class={`font-medium py-3 px-3 rounded-lg transition-all duration-200 block ${
								isActive
									? 'text-blue-600 bg-blue-50'
									: 'text-gray-700 hover:text-blue-600 hover:bg-blue-50'
							}`}
						>
							{item.name}
						</a>
					);
				})}
				
				<!-- Mobile ACCESORIOS Dropdown -->
				<button id="mobile-accesorios-btn" class="font-medium py-3 px-3 rounded-lg transition-all duration-200 w-full flex items-center justify-between text-gray-700 hover:text-blue-600 hover:bg-blue-50">
					ACCESORIOS
					<svg id="mobile-accesorios-icon" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
					</svg>
				</button>
				<div id="mobile-accesorios-menu" class="hidden bg-gray-50 rounded-lg py-1 px-2">
					{accesorios.map((item) => {
						const isActive = currentPath === item.href;
						return (
							<a
								href={item.href}
								class={`font-medium py-2 px-3 rounded-lg transition-all duration-200 block text-sm ${
									isActive
										? 'text-blue-600 bg-white'
										: 'text-gray-700 hover:text-blue-600 hover:bg-white'
								}`}
							>
								{item.name}
							</a>
						);
					})}
				</div>

				<div class="pt-3 border-t border-gray-100 mt-3 relative">
					<input
						type="text"
						placeholder="Buscar..."
						class="w-full bg-gray-50 border border-gray-200 rounded-lg py-2.5 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white text-sm font-medium"
					/>
					<svg
						class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
						></path>
					</svg>
				</div>
			</div>
		</nav>
	</div>
</header>

<script>
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');
	const mobileAccesoriosBtn = document.getElementById('mobile-accesorios-btn');
	const mobileAccesoriosMenu = document.getElementById('mobile-accesorios-menu');
	const mobileAccesoriosIcon = document.getElementById('mobile-accesorios-icon');

	if (mobileMenuBtn && mobileMenu) {
		mobileMenuBtn.addEventListener('click', () => {
			mobileMenu.classList.toggle('hidden');
		});

		// Cerrar menú al hacer click en un enlace
		mobileMenu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				mobileMenu.classList.add('hidden');
			});
		});
	}

	// Manejo del dropdown de accesorios en móvil
	if (mobileAccesoriosBtn && mobileAccesoriosMenu) {
		mobileAccesoriosBtn.addEventListener('click', (e) => {
			e.preventDefault();
			mobileAccesoriosMenu.classList.toggle('hidden');
			mobileAccesoriosIcon?.classList.toggle('rotate-180');
		});

		// Cerrar dropdown al hacer click en un enlace
		mobileAccesoriosMenu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				mobileAccesoriosMenu.classList.add('hidden');
				mobileAccesoriosIcon?.classList.remove('rotate-180');
				mobileMenu?.classList.add('hidden');
			});
		});
	}
</script>
