---

<section 
	class="relative py-20 sm:py-32 md:py-40 lg:py-48 overflow-hidden bg-cover bg-center bg-fixed"
	style="background-image: url('/Logos/portadaPrincipal.jpg');"
>
	<!-- Overlay oscuro para mejor legibilidad -->
	<div class="absolute inset-0 bg-black/45"></div>
	
	<div class="container mx-auto px-4 relative z-10">
		<div class="max-w-3xl mx-auto">
			<div class="text-center">
				<h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 sm:mb-6 leading-tight">
					Transforma tus Espacios<br />
					<span class="bg-gradient-to-r from-blue-400 to-blue-300 bg-clip-text text-transparent">
						con Cerámica Premium
					</span>
				</h1>
				<p class="text-base sm:text-lg md:text-xl text-gray-100 mb-6 sm:mb-8 max-w-2xl mx-auto leading-relaxed">
					Cerámicas y porcelanatos de alta calidad para baños, cocinas, salas y terrazas. Diseño, durabilidad y elegancia garantizada.
				</p>
				<div class="flex justify-center">
					<a
						href="/banos"
						class="inline-block bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 text-white font-semibold py-3 sm:py-4 px-6 sm:px-8 rounded-lg shadow-lg hover:shadow-xl transition-all duration-200 transform hover:scale-105 active:scale-95"
					>
						Explorar Catálogo
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
