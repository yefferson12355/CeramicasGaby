---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Cerámicas Gabi - Transformamos tus Espacios con Estilo</title>
		<meta name="description" content="Cerámicas y porcelanatos de alta calidad para transformar tus espacios" />
		<meta property="og:title" content="Cerámicas Gabi" />
		<meta property="og:description" content="Tu mejor opción en cerámicas y porcelanatos" />
	</head>
	<body class="min-h-screen flex flex-col bg-gray-50 antialiased">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
		<WhatsAppButton />
	</body>
</html>

<style is:global>
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: system-ui, -apple-system, sans-serif;
	}

	img {
		display: block;
		max-width: 100%;
		height: auto;
	}

	a {
		text-decoration: none;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1rem;
	}
</style>
