---
import Layout from '../layouts/Layout.astro';
import Welcome from '../components/Welcome.astro';
import CategoryShowcase from '../components/CategoryShowcase.astro';

const cocinaProducts = [
	{
		title: 'CERÁMICA COCINA PREMIUM',
		image: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&h=600&fit=crop',
		description: 'Cerámica especial para cocinas con acabado resistente y fácil limpieza',
		category: 'Cocina',
		price: 'Consultar'
	}
];
---

<Layout>
	<CategoryShowcase
		title="Colección Premium de Cocinas"
		description="Transforma tu cocina con cerámicas de alta resistencia. Descubre todos los materiales y herramientas necesarias para una instalación profesional y duradera."
		heroImage="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&h=600&fit=crop"
		category="cocinas"
	/>

	<div class="container mx-auto px-4 py-12">
		<h2 class="text-3xl font-bold text-gray-900 mb-8">Productos Destacados para Cocinas</h2>
		<Welcome
			title="Productos Destacados"
			description="Explora nuestra selección de cerámicas especializadas para cocinas"
			products={cocinaProducts}
			sectionId="cocina"
		/>
	</div>
</Layout>
