---
import Layout from '../layouts/Layout.astro';
import Welcome from '../components/Welcome.astro';

const terrazaProducts = [
	{
		title: 'CERÁMICA TERRAZA OUTDOOR',
		image: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&h=600&fit=crop',
		description: 'Porcelanatos resistentes y duraderos para exteriores',
		category: 'Terraza',
		price: 'Consultar'
	}
];
---

<Layout>
	<Welcome
		title="Colección de Terrazas"
		description="Cerámicas robustas para espacios exteriores"
		products={terrazaProducts}
		sectionId="terraza"
	/>
</Layout>
